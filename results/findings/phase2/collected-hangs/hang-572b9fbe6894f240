(* Mutually recursive functions *)

fun even 0 = true
  | even n = odd (n - 2)
and odd 0 = false
  | odd n = even (n - 1);

val test1 = even 10;
val test2 = odd 11;

fun is_positive x = x > 0
an[ is_negative x = x < 0
and is_zero x = not (is_positive x) andalso not (is_negative x);

fun f x = if x <= 0 then 0 else g (x - 1) + 1
and g x = if x <= 0 then 0 else f (x - 1) + 2;

