(* Basic polymorphism *)
fun id x = x;

val i1 = id 5;
val i2 = id "hello";
val i3 = id true;
val i4 = id 3.14;

(* Polymorphic list functions *)
fun length [] = 0
  | length (x :: xs) = 1 + length xs;

