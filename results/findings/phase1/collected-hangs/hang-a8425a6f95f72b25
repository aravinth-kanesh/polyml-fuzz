(* Higher-order polymorphic functions *)
fun map f [] = []
  | map f (x :: xs) = f x :: map f xs;

fun filter p [] = []
  | filter p (x :: xs) = if p x then x :: filter p xs else filter p xs;

fun foldl f acval sum = foldl (fn (acc, x) => acc + x) 0 [1, 2, 3, 4, 5];
val product = foldl (fn (acc, x) => acc * x) 1 [1, 2, 3, 4, 5];

(* Polymorphic datatypes *)
datatype 'a option = NONE | SOME of 'a;
datatype ('b) either = Left of 'aE = NONE
  | mn f (SOME x) = SOME (f x);

val o1 = maph (Left x) = x
  | either_value (Right y) = y;

(* Constrained polymorphism *)
fun equals (x: ''a) (y: ''a) = x = y;

