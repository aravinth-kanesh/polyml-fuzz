infix 6 +;
infix 6 -;
infix 7 *;
infix 7 /;

fun (a: int) + (b: int) = a + b;  (* Shadows built-in *)
fun (a: int) - (b: int) = a - b;
fun (a: int) * (b: int) = a * b;
fun (a: int) / (b: int) = a div b;

(* Very long operator names *)
infix 5 very_long_operator_name_that_goes_on_and_on;
