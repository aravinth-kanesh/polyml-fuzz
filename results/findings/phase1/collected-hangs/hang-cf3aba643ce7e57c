val r1 = 5 very_long_operator_name_that_goes_on_and_on 3;

(* Operators with numbers *)
infix 6 +1;
infix 6 *2;
infix 6 ^3;

fun a +1 b = a + b + 1;
fun a *2 b = a * b * 2;
fun a ^3 b = a * a * a + b;

val r2 = 5 +1 3;
val r3 = 4 *2 2;
val r4 = 2 ^3 1;

